<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".WorkbenchApplication"
        android:allowBackup="true"
        android:label="Haptics Workbench"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.DarkActionBar">

        <!-- Main experience: the Compose workbench (design + feel on the real actuator). -->
        <activity
            android:name=".WorkbenchActivity"
            android:exported="true"
            android:label="Haptics Workbench"
            android:theme="@android:style/Theme.Material.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The flat feel-test gallery, reachable from the workbench's "Gallery" button. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Feel-test gallery" />
    </application>
</manifest>
